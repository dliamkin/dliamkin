		"scaffold_code": "\n<script setup lang=\"ts\">\nimport { ref } from 'vue'\nimport Card from 'primevue/card'\nimport Chart from 'primevue/chart'\nimport DataTable from 'primevue/datatable'\nimport Column from 'primevue/column'\nimport TabMenu from 'primevue/tabmenu'\nimport Tag from 'primevue/tag'\nimport Avatar from 'primevue/avatar'\n\nconst activeTab = ref(0)\n\nconst tabs = [\n  { label: 'Overview', icon: '' },\n  { label: 'Reports', icon: '' },\n  { label: 'Segments', icon: '' },\n  { label: 'Settings', icon: '' }\n]\n\nconst metrics = [\n  { label: 'ACTIVE USERS', value: '12,481', change: 8.2, direction: 'up' },\n  { label: 'SESSIONS', value: '48,902', change: 3.1, direction: 'up' },\n  { label: 'BOUNCE RATE', value: '31.4%', change: 1.8, direction: 'down' },\n  { label: 'AVG. DURATION', value: '4m 12s', change: 0.4, direction: 'up' }\n]\n\nconst chartData = {\n  labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],\n  datasets: [\n    {\n      label: 'Sessions',\n      data: [3500, 4200, 3800, 5100, 4600, 5800, 4400],\n      backgroundColor: '#3B82F6'\n    }\n  ]\n}\n\nconst chartOptions = {\n  responsive: true,\n  maintainAspectRatio: true,\n  plugins: {\n    legend: { display: false }\n  }\n}\n\nconst topPages = [\n  { page: '/home', views: 18204, status: 'Healthy' },\n  { page: '/pricing', views: 9876, status: 'Healthy' },\n  { page: '/docs/setup', views: 7431, status: 'Slow' },\n  { page: '/blog/launch', views: 5208, status: 'Healthy' },\n  { page: '/changelog', views: 3990, status: 'Healthy' }\n]\n\nconst getSeverity = (status: string) => {\n  if (status === 'Healthy') return 'success'\n  if (status === 'Slow') return 'warning'\n  return 'danger'\n}\n</script>\n\n<template>\n  <div class=\"dashboard-container\">\n    <!-- Header -->\n    <div class=\"header\">\n      <div class=\"logo-section\">\n        <Avatar label=\"A\" style=\"background-color: #3B82F6; color: #fff\" />\n        <span class=\"app-title\">Acmetrics</span>\n      </div>\n      <TabMenu :model=\"tabs\" :activeIndex=\"activeTab\" />\n      <div class=\"user-profile\">\n        <span>User Name</span>\n        <Avatar label=\"JP\" style=\"background-color: #F59E0B\" />\n      </div>\n    </div>\n\n    <!-- Main Content -->\n    <div class=\"main-content\">\n      <h1>Overview</h1>\n\n      <!-- Metrics Grid -->\n      <div class=\"metrics-grid\">\n        <Card v-for=\"metric in metrics\" :key=\"metric.label\">\n          <template #content>\n            <p class=\"metric-label\">{{ metric.label }}</p>\n            <p class=\"metric-value\">{{ metric.value }}</p>\n            <Tag\n              :value=\"`${metric.direction === 'up' ? '▲' : '▼'} ${metric.change}%`\"\n              :severity=\"metric.direction === 'up' ? 'success' : 'danger'\"\n            />\n          </template>\n        </Card>\n      </div>\n\n      <!-- Charts and Tables Grid -->\n      <div class=\"content-grid\">\n        <!-- Weekly Sessions Chart -->\n        <Card>\n          <template #content>\n            <h3>Weekly sessions</h3>\n            <Chart type=\"bar\" :data=\"chartData\" :options=\"chartOptions\" />\n          </template>\n        </Card>\n\n        <!-- Top Pages Table -->\n        <Card>\n          <template #content>\n            <h3>Top pages</h3>\n            <DataTable :value=\"topPages\" responsiveLayout=\"scroll\">\n              <Column field=\"page\" header=\"PAGE\" />\n              <Column field=\"views\" header=\"VIEWS\" />\n              <Column field=\"status\" header=\"STATUS\">\n                <template #body=\"{ data }\">\n                  <Tag :value=\"data.status\" :severity=\"getSeverity(data.status)\" />\n                </template>\n              </Column>\n            </DataTable>\n          </template>\n        </Card>\n      </div>\n    </div>\n  </div>\n</template>\n\n<style scoped>\n.dashboard-container {\n  background-color: #f9fafb;\n  min-height: 100vh;\n}\n\n.header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 1rem 2rem;\n  background-color: #fff;\n  border-bottom: 1px solid #e5e7eb;\n}\n\n.logo-section {\n  display: flex;\n  align-items: center;\n  gap: 0.75rem;\n  font-size: 1.25rem;\n  font-weight: 600;\n}\n\n.app-title {\n  color: #1f2937;\n}\n\n.user-profile {\n  display: flex;\n  align-items: center;\n  gap: 0.75rem;\n  font-size: 0.875rem;\n  color: #6b7280;\n}\n\n.main-content {\n  padding: 2rem;\n  max-width: 1400px;\n  margin: 0 auto;\n}\n\n.main-content h1 {\n  font-size: 2rem;\n  font-weight: 700;\n  color: #1f2937;\n  margin-bottom: 2rem;\n}\n\n.metrics-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));\n  gap: 1.5rem;\n  margin-bottom: 2rem;\n}\n\n.metric-label {\n  font-size: 0.75rem;\n  font-weight: 600;\n  color: #9ca3af;\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  margin: 0;\n}\n\n.metric-value {\n  font-size: 2rem;\n  font-weight: 700;\n  color: #1f2937;\n  margin: 0.5rem 0;\n}\n\n.content-grid {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 2rem;\n}\n\n.content-grid h3 {\n  font-size: 1.125rem;\n  font-weight: 600;\n  color: #1f2937;\n  margin-bottom: 1.5rem;\n}\n\n@media (max-width: 768px) {\n  .header {\n    flex-direction: column;\n    gap: 1rem;\n  }\n\n  .content-grid {\n    grid-template-columns: 1fr;\n  }\n\n  .metrics-grid {\n    grid-template-columns: 1fr;\n  }\n}\n</style>\n",
