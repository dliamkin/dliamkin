{
  "name": "dliamkin",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bash ./scripts/dev.sh",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s \"lint:*\"",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "start": "npm run dev",
    "dev:linux": "node ./scripts/dev.mjs",
    "generate:og": "node ./scripts/generate-og.mjs",
    "generate:samples": "tsx ./scripts/generate-samples.mjs",
    "generate:screenshot-samples": "tsx ./scripts/generate-screenshot-samples.mjs",
    "generate:lease-samples": "tsx ./scripts/generate-lease-samples.mjs",
    "generate:paperwork-samples": "tsx ./scripts/generate-paperwork-samples.mjs",
    "generate:upgrade-samples": "tsx ./scripts/generate-upgrade-samples.mjs",
    "audit:local": "tsx ./scripts/site-health/run-audit.ts",
    "eval": "tsx ./scripts/evals/run-evals.ts",
    "tos-watch:run": "tsx ./scripts/tos-watch/run.ts",
    "tos-watch:shakeout": "tsx ./scripts/tos-watch/shakeout.ts",
    "ml:generate-data": "tsx ./ml/datagen/index.ts",
    "ml:train": "ml/train/.venv/bin/python ml/train/train.py",
    "ml:export": "ml/train/.venv/bin/python ml/train/export_onnx.py"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@fortawesome/fontawesome-free": "^6.7.2",
