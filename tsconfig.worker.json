// TSConfig for the Cloudflare Worker (bundled by wrangler, type-checked here).
// Uses Node's types (fetch/Request/Response via undici) rather than
// @cloudflare/workers-types, which conflicts with the @types/node globals the
// Anthropic SDK pulls in. The Worker only touches web-standard APIs.
{
  "extends": "@tsconfig/node24/tsconfig.json",
  "include": ["worker/**/*", "src/lib/structured-note.ts"],
  "compilerOptions": {
    "module": "preserve",
    "moduleResolution": "bundler",
    "types": ["node"],
    "noUncheckedIndexedAccess": true,

    // Type-checking only — wrangler does the actual bundling.
    "noEmit": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.worker.tsbuildinfo"
  }
}
